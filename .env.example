# ─── Client-side (exposed in bundle, prefixed VITE_) ───
# Meta Pixel ID — from Meta Events Manager → Data Sources → your pixel
VITE_META_PIXEL_ID=

# ─── Server-side (Vercel Function env vars, never exposed) ───
# Same Pixel ID as above
META_PIXEL_ID=

# Long-lived access token — Events Manager → your pixel → Settings → Conversions API
META_CAPI_TOKEN=

# Optional: test event code during setup — Events Manager → Test Events → Browser events
# Remove once production traffic is verified
META_CAPI_TEST_CODE=
